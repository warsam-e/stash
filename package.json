{
	"name": "@warsam-e/stash",
	"description": "A simple and flexible caching library for TypeScript",
	"version": "1.3.4",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		}
	},
	"type": "module",
	"license": "MIT",
	"files": [
		"dist"
	],
	"scripts": {
		"build:lib": "tsdown",
		"build:docs": "typedoc --options typedoc.json",
		"build": "bun build:lib && bun build:docs",
		"dev": "bun test --watch",
		"check": "biome check"
	},
	"devDependencies": {
		"@types/bun": "1.3.13",
		"arkenv": "0.12.2",
		"arktype": "2.2.1",
		"tsdown": "0.22.3",
		"typedoc-github-theme": "0.4.0",
		"typescript": "6.0.3"
	},
	"dependencies": {
		"bun.db": "1.1.5",
		"chrono-node": "2.9.1",
		"mongoose": "9.7.2",
		"mongodb": "7.3.0",
		"redis": "6.0.1"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/warsam-e/stash.git"
	},
	"bugs": {
		"url": "https://github.com/warsam-e/stash/issues"
	},
	"homepage": "https://warsame.me/stash"
}
